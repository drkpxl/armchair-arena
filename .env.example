# Copy to .env and fill in. The real .env is gitignored.

# --- Model backend (Ollama, native /api/chat) ---
# Option A — Ollama Cloud (no local GPU needed): use the cloud host + an API key
#   from https://ollama.com/settings/keys
# Option B — a local Ollama daemon: set OLLAMA_HOST=http://localhost:11434 and
#   leave OLLAMA_API_KEY blank.
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=

# --- Web-research tool backend (self-hosted Firecrawl) ---
# https://github.com/firecrawl/firecrawl — used for the web_search / scrape_url tools.
FIRECRAWL_URL=http://localhost:3002

# --- Web service bind address ---
# 127.0.0.1 = local only. 0.0.0.0 = reachable from your network (NOTE: the app has
# NO authentication — only expose it on a trusted/private network, e.g. a VPN/tailnet).
BIND_HOST=127.0.0.1
PORT=8090

# Hide models not updated within this many days (0 = show all).
MAX_MODEL_AGE_DAYS=365

# Hide models whose name contains any of these substrings (case-insensitive).
# Default drops coding/dev-tuned models. Set empty to show all.
EXCLUDE_MODEL_PATTERNS=coder,code,devstral

# Optional region/locale context added to every model's system prompt so answers use
# the right units, date format, spelling, and "near me" results. Empty = omitted.
# Example: "The user is in the United States (Mountain Time); prefer US units (°F, miles),
# US spelling, MM/DD/YYYY dates, and USD."
USER_LOCALE=

# Tool loop + truncation knobs
MAX_TOOL_ITERS=5
SEARCH_SNIPPET_CHARS=1500
SCRAPE_CHARS=6000
REQUEST_TIMEOUT=300
